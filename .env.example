# PostgreSQL (docker-compose)
POSTGRES_USER=server
POSTGRES_PASSWORD=password
POSTGRES_DB=axum_shop

# Server
DATABASE_URL=postgresql://server:password@localhost:5432/axum_shop
JWT_SECRET=change-me-in-production
JWT_EXPIRED_IN=60m
HOST=127.0.0.1
PORT=8080

# Optional: enable SQLx compile-time query checking without a live DB
# SQLX_OFFLINE=true
